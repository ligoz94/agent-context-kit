{
  "name": "agent-context-kit",
  "private": true,
  "description": "Monorepo: CLI and MCP toolshed server for agent context kits",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:cli": "npm run build -w @agent-context-kit/cli",
    "build:server": "npm run build -w @agent-context-kit/toolshed-server",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:mcp": "npm run test:mcp -w @agent-context-kit/toolshed-server",
    "test:all": "npm test && npm run test:mcp",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
